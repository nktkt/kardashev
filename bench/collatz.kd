// Branches + div/mod: total Collatz steps for n in 1..3,000,000.
fn main() -> i64 ! { io } {
    let mut steps = 0; let mut n = 1;
    while n < 3000000 {
        let mut x = n;
        while x > 1 { if x % 2 == 0 { x = x / 2; } else { x = 3 * x + 1; } steps = steps + 1; }
        n = n + 1;
    }
    print(steps); 0                                  // 428343355
}

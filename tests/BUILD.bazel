# Phase 20a: opt-level flags (-O0..-O3) + the `kardc --test` runner + the RPN
# capstone. The capstone program text is inlined in the script so the Bazel
# sandbox needs no extra source data beyond kardc itself.
sh_test(
    name = "smoke_test_toolchain",
    srcs = ["smoke_test_toolchain.sh"],
    data = ["//compiler:kardc"],
)

# Phase 22: fixed-size arrays `[T; N]` + tuples `(A, B)` — literals, indexing,
# fn params/returns, struct fields, mutation, `let` destructuring, nesting, and
# negative cases; through JIT + AOT.
sh_test(
    name = "smoke_test_aggregates",
    srcs = ["smoke_test_aggregates.sh"],
    data = ["//compiler:kardc"],
)

# Phase 23: real panic + unwinding (setjmp/longjmp + a runtime cleanup stack) —
# Drop runs on unwind (reverse order), `catch` recovers, an uncaught panic
# exits 101 with a stderr message, exactly-once drops on the normal AND panic
# paths (no double-free / leak, incl. a 100k-unwind heap-Vec loop), array `[T;N]`
# OOB indexing panics, and panic/catch effect-checking is consistent; JIT + AOT.
sh_test(
    name = "smoke_test_panic",
    srcs = ["smoke_test_panic.sh"],
    data = ["//compiler:kardc"],
)

# Phase 24: user-declarable `extern "C"` FFI — calling libc fns (abs/strlen/
# putchar/getpid) with correct C-int width handling (i32 narrow/widen), the
# &String -> C-pointer mapping, and the `io` effect carried by extern calls;
# through JIT + AOT.
sh_test(
    name = "smoke_test_ffi",
    srcs = ["smoke_test_ffi.sh"],
    data = ["//compiler:kardc"],
)

# Phase 25: compile-time constants + const evaluation — `const` items folded to
# literals (verified in the IR), `const fn` evaluated in const contexts, a const
# referencing another const, const-generic array lengths (`[i64; N]` /
# `[i64; sq(2)]`, lifting Phase 22's literal-only N), a const fn still usable at
# runtime, and clear (bounded, non-crashing) errors for div0 / non-evaluable /
# cyclic / runaway / overflow; through JIT + AOT.
sh_test(
    name = "smoke_test_const",
    srcs = ["smoke_test_const.sh"],
    data = ["//compiler:kardc"],
)

